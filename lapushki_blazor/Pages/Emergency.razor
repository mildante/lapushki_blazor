@page "/emergency"
@using lapushki_blazor.ApiRequests.Services

<PageTitle>Экстренная помощь</PageTitle>

<div class="emergency-page">
    <section class="emergency-hero">
        <h1 class="emergency-title">Экстренная помощь</h1>

        <p class="emergency-text">
            Клиника "Лапушки" работает
            <span class="emergency-highlight">каждый день круглосуточно</span>
        </p>

        <a class="emergency-call-btn" href="tel:+79999999999">Позвонить</a>
        <section class="emergency-info">
            <div class="clinic-info-card">
                <h2 class="clinic-title">Как нас найти</h2>

                <div class="clinic-address">
                    <strong>Адрес:</strong> ул. Большая Красная, д. 61
                </div>

                <div class="clinic-stop">
                    <strong>Остановка:</strong> Улица Толстого
                </div>

                <div class="clinic-transport">
                    <div class="transport-group">
                        <div class="transport-title">Автобусы</div>
                        <div class="transport-list">
                            <span>10а</span>
                            <span>22</span>
                            <span>28</span>
                            <span>30</span>
                            <span>35</span>
                            <span>54</span>
                            <span>89</span>
                            <span>91</span>
                        </div>
                    </div>

                    <div class="transport-group">
                        <div class="transport-title">Троллейбусы</div>
                        <div class="transport-list blue">
                            <span>2</span>
                            <span>3</span>
                            <span>5</span>
                            <span>7</span>
                            <span>8</span>
                        </div>
                    </div>
                </div>

                <div class="clinic-phone">
                    <strong>Телефон:</strong>
                    <a href="tel:+78001234567">+7 (800) 123-45-67</a>
                </div>
            </div>
        </section>
    </section>
</div>

@code {
    [Inject] private UserRequests UserRequests { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await UserRequests.LoadUserFromToken();
    }
}