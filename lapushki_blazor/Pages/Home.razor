@page "/"
@using lapushki_blazor.ApiRequests.Services

<PageTitle>Лапушки</PageTitle>

<div class="home-page">

    <section class="home-hero">
        <div class="home-hero-text">
            <div class="home-label">
                <i class="bi bi-heart-fill"></i>
                Забота о питомцах каждый день
            </div>

            <h1>Ветеринарная клиника «Лапушки»</h1>

            <p>
                Помогаем питомцам чувствовать себя лучше: консультации,
                диагностика, вакцинация, лечение и экстренная помощь.
            </p>

            <div class="home-hero-actions">
                <a class="home-main-btn" href="/servicesPage">
                    Записаться на приём
                </a>

                <a class="home-outline-btn" href="/contacts">
                    Контакты
                </a>
            </div>
        </div>

        <div class="home-hero-image">
            <img src="/images/lapushki_logo_blue.png" alt="Питомцы" />
        </div>
    </section>

    <section class="home-cards">
        <div class="home-card">
            <div class="home-icon">
                <i class="bi bi-clipboard2-pulse-fill"></i>
            </div>
            <h3>Приём врача</h3>
            <p>Осмотр, консультация и подбор лечения для вашего питомца.</p>
        </div>

        <div class="home-card">
            <div class="home-icon">
                <i class="bi bi-shield-check"></i>
            </div>
            <h3>Вакцинация</h3>
            <p>Профилактика заболеваний и ежегодная защита животных.</p>
        </div>

        <div class="home-card">
            <div class="home-icon">
                <i class="bi bi-heart-pulse-fill"></i>
            </div>
            <h3>Диагностика</h3>
            <p>Помогаем быстро понять причину плохого самочувствия.</p>
        </div>

        <div class="home-card">
            <div class="home-icon">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <h3>Экстренная помощь</h3>
            <p>Подскажем, что делать, если питомцу срочно нужна помощь.</p>
        </div>
    </section>

    <section class="home-info-row">

        <div class="home-info-card">
            <h2>Почему выбирают нас</h2>

            <div class="home-benefit">
                <i class="bi bi-check-circle-fill"></i>
                <span>Внимательное отношение к каждому питомцу</span>
            </div>

            <div class="home-benefit">
                <i class="bi bi-check-circle-fill"></i>
                <span>Удобная запись через сайт</span>
            </div>

            <div class="home-benefit">
                <i class="bi bi-check-circle-fill"></i>
                <span>Понятные рекомендации после приёма</span>
            </div>

            <div class="home-benefit">
                <i class="bi bi-check-circle-fill"></i>
                <span>Помощь при плановых и срочных обращениях</span>
            </div>
        </div>

        <div class="home-contact-card">
            <div class="home-icon">
                <i class="bi bi-telephone-fill"></i>
            </div>

            <h2>Нужна консультация?</h2>
            <p>Позвоните нам или выберите услугу на сайте.</p>

            <strong>+7 (999) 123-45-67</strong>

            <a class="home-main-btn" href="/contacts">
                Как нас найти
            </a>
        </div>

    </section>

</div>

@code {
    [Inject] private UserRequests UserRequests { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await UserRequests.LoadUserFromToken();
    }
}