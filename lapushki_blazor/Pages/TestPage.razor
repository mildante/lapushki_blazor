@page "/test"

<div class="gw-page">
    <div class="gw-shell">

        <header class="gw-topbar">
            <div class="gw-nav-icons">
                <a href="#" class="gw-nav-icon" title="Главная">
                    <i class="bi bi-house-door"></i>
                </a>

                <a href="#" class="gw-nav-icon" title="Игры">
                    <i class="bi bi-controller"></i>
                </a>

                <a href="#" class="gw-nav-icon" title="Статистика">
                    <i class="bi bi-bar-chart"></i>
                </a>

                <a href="#" class="gw-nav-icon active" title="Профиль">
                    <i class="bi bi-person"></i>
                </a>
            </div>

            <div class="gw-logo">
                GuessWord
            </div>
        </header>

        <main class="gw-main">
            <div class="gw-auth-card">
                <h1 class="gw-auth-title">Авторизация</h1>

                <div class="gw-form-group">
                    <label for="login">Логин:</label>
                    <input id="login" type="text" placeholder="Логин" />
                </div>

                <div class="gw-form-group">
                    <label for="password">Пароль:</label>
                    <input id="password" type="password" placeholder="Логин" />
                </div>

                <div class="gw-form-message">
                    Заполните все поля!
                </div>

                <button class="gw-login-btn">Войти</button>

                <div class="gw-register-link">
                    Еще нет аккаунта?
                    <a href="/register">Зарегистрироваться</a>
                </div>
            </div>
        </main>

        <footer class="gw-footer">
            GuessWord&nbsp;&nbsp;|&nbsp;&nbsp;Играй, угадывай, побеждай
        </footer>

    </div>
</div>