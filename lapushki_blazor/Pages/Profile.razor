@page "/profile"
@using lapushki_blazor.ApiRequests.Models
@using lapushki_blazor.ApiRequests.Services
@using static lapushki_blazor.ApiRequests.Models.Pet
@using static lapushki_blazor.ApiRequests.Models.User

@inject NavigationManager Navigation

<div class="profile-page">
    
    @if (!string.IsNullOrWhiteSpace(responseMessage))
    {
        <div class="profile-message">
            @responseMessage
        </div>
    }

    <div class="profile-layout">

        <section class="pets-section">
            @if (updateUser.role_id == 3)
            {
                <div class="profile-card-header">
                    <div>
                        <h2>Ваши питомцы</h2>
                        <p>Добавляйте и редактируйте информацию о питомцах</p>
                    </div>
                </div>

                @if (userPets == null)
                {
                    <div>Загрузка...</div>
                }
                else if (userPets.Count == 0)
                {
                    <div class="empty-pets-text">У вас пока нет питомцев</div>
                    <button type="button" class="add-pet-btn" @onclick="AddPet">Добавить питомца +</button>
                }
                else
                {
                    <div class="profile-card">
                        <div class="pets-card-wrapper">
                            <button type="button" class="slider-arrow left" @onclick="PrevPet" disabled="@isAddMode">
                                <i class="bi bi-caret-left-fill"></i>
                            </button>

                            <div class="pets-card @animateDirection">
                                <div class="pet-form-column">
                                    <div class="form-group">
                                        <label>Кличка</label>
                                        <input class="profile-input" type="text" @bind="CurrentPet.name" />
                                    </div>

                                    <div class="form-group">
                                        <label>Порода</label>
                                        <input class="profile-input" type="text" @bind="CurrentPet.breed"/>
                                    </div>

                                    <div class="form-group">
                                        <label>Вид</label>
                                        <input class="profile-input" type="text" @bind="CurrentPet.species"/>
                                        <div class="hint-text">*кошка/собака/еж и т.п.</div>
                                    </div>

                                    <div class="form-row">
                                        <div class="form-group half">
                                            <label>Дата рождения</label>
                                            <input class="profile-input" type="date" @bind="CurrentPet.date_of_birth" />
                                            <div class="hint-text">*не знаете точную дату? укажите примерную</div>
                                        </div>

                                        <div class="form-group half">
                                            <label>Пол</label>
                                            <input class="profile-input" type="text" @bind="CurrentPet.gender" />
                                            <div class="hint-text">*м/ж</div>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label>Особые приметы</label>
                                        <textarea class="profile-textarea" @bind="CurrentPet.description" placeholder="Необязательное поле"></textarea>
                                    </div>
                                </div>

                                <div class="pet-image-column">
                                    <div class="pet-photo-box @(string.IsNullOrEmpty(CurrentPet.image) ? "empty" : "")">
                                        @if (!string.IsNullOrEmpty(CurrentPet.image))
                                        {
                                            <img src="@CurrentPet.image" class="pet-photo" />
                                        }
                                        else
                                        {
                                            <div class="photo-placeholder">
                                                <span>+</span>
                                            </div>
                                        }
                                    </div>

                                    <div>
                                        <InputFile id="petFileInput"
                                                   class="d-none"
                                                   accept="image/*"
                                                   OnChange="OnPetImageSelected" />

                                        <label for="petFileInput" class="change-link-btn">
                                            Изменить
                                        </label>
                                    </div>
                                </div>
                           
                            </div>

                            <div class="pet-actions">
                                <button type="button" class="save-btn" @onclick="SavePet">Сохранить</button>
                                <button type="button" class="delete-btn" @onclick="DeletePet">Удалить</button>
                            </div>

                            <button type="button" class="slider-arrow right" @onclick="NextPet" disabled="@isAddMode">
                                <i class="bi bi-caret-right-fill"></i>
                            </button>
                        </div>
                    </div>


                    <button type="button" class="add-pet-btn" @onclick="AddPet">Добавить питомца +</button>
                }
            }
            else if (updateUser.role_id == 1)
            {
                <div class="profile-panel-card">
                    <div class="profile-panel-icon">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>

                    <div class="profile-panel-content">
                        <h2>Панель администратора</h2>
                        <p>У вас есть права администратора. Вы можете управлять пользователями, врачами, питомцами и записями.</p>
                    </div>

                    <button type="button" class="profile-panel-btn" @onclick="GoToAdminPanel">
                        Админ панель
                    </button>
                </div>
            }
            else if (updateUser.role_id == 2)
            {
                <div class="profile-panel-card">
                    <div class="profile-panel-icon">
                        <i class="bi bi-clipboard2-pulse-fill"></i>
                    </div>

                    <div class="profile-panel-content">
                        <h2>Панель врача</h2>
                        <p>Вы можете перейти к записям и оформить запись питомца на приём без оплаты.</p>
                    </div>

                    <button type="button" class="profile-panel-btn" @onclick="GoToDoctorPanel">
                        Перейти к записям
                    </button>
                </div>
            }

        </section>

        <section class="user-section">
            <div class="profile-card-header">
                <div class="profile-card-text">
                    <h2>Ваш профиль</h2>
                    <p>Изменяйте личные данные в любое время</p>
                </div>
            </div>

            <div class="profile-card">            
                <div class="user-card">
                    <div class="avatar-block">
                        <img src="@updateUser.avatar" class="avatar-circle" />
                        <InputFile id="userFileInput"
                                   class="d-none"
                                   accept="image/*"
                                   OnChange="OnProfileImageSelected" />

                        <label for="userFileInput" class="change-link-btn">
                            Изменить
                        </label>
                    </div>

                    <div class="form-group">
                        <label>Имя</label>
                        <input class="profile-input" type="text" @bind="updateUser.name" />
                    </div>

                    <div class="form-group">
                        <label>Фамилия</label>
                        <input class="profile-input" type="text" @bind="updateUser.surname" />
                    </div>

                    <div class="form-row">
                        <div class="form-group half">
                            <label>Дата рождения</label>
                            <input class="profile-input" type="date" @bind="updateUser.date_of_birth" />
                        </div>

                        <div class="form-group half">
                            <label>Пол</label>
                            <input class="profile-input" type="text" @bind="updateUser.gender" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Номер телефона</label>
                        <input class="profile-input" type="text" @bind="updateUser.phone" />
                    </div>

                    <div class="form-group">
                        <label>Почта</label>
                        <input class="profile-input" type="email" @bind="updateUser.email" />
                    </div>

                    <div class="form-group">
                        <label>Пароль</label>
                        <input class="profile-input" type="password" @bind="updateUser.password" />
                    </div>

                    <button type="button" class="save-btn" @onclick="SaveProfile">Сохранить</button>
                </div>
            </div>
        </section>
    </div>

    @if (!userService.isDoctor && !userService.isAdmin)
    {
        <div class="appointments-card">
            <div class="appointments-icon">
                <i class="bi bi-calendar-heart-fill"></i>
            </div>

            <div class="appointments-content">
                <h2>Ваши записи</h2>
                <p>Здесь вы можете посмотреть свои записи на приём.</p>
            </div>

            <button type="button" class="appointments-btn" @onclick="GoToDoctorPanel">
                Перейти к записям
            </button>
        </div>
    }

    
    <button class="logout-btn" @onclick="Logout">
        <i class="bi bi-box-arrow-right"></i> Выйти из аккаунта
    </button>
</div>
@code {
    [Inject] private UserService userService { get; set; }

    [Inject] private UserRequests UserRequests { get; set; }
    [Inject] private PetRequests PetRequests { get; set; }
    [Inject] private ImageLoader imageLoader { get; set; }


    private string animateDirection = "";

    private UserModel updateUser = new UserModel();

    private List<PetModel> userPets;
    private int currentPetIndex = 0;
    private PetModel CurrentPet => userPets[currentPetIndex];

    private bool isAddMode = false;
    private bool isEditMode = true;

    private string responseMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await UserRequests.LoadUserFromToken();

        responseMessage = "";
        updateUser = userService.CurrentUser;

        if (updateUser.role_id == 3)
        {
            var getPetResponse = await PetRequests.GetAllPetsByUser(userService.CurrentUser.id_user);
            userPets = getPetResponse.list ?? new List<PetModel>();
        }
    }

    private void GoToAdminPanel()
    {
        Navigation.NavigateTo("/admin");
    }

    private void GoToDoctorPanel()
    {
        Navigation.NavigateTo("/appointmentsPage");
    }

    private void NextPet()
    {
        if (userPets == null || userPets.Count == 0)
            return;

        if (currentPetIndex < userPets.Count - 1)
        {
            currentPetIndex++;
            SwitchCard("right");
        }
        else if (currentPetIndex >= userPets.Count - 1)
        {
            currentPetIndex = 0;
            SwitchCard("right");
        }
    }

    private void PrevPet()
    {
        if (userPets == null || userPets.Count == 0)
            return;
        if (currentPetIndex > 0)
        {
            currentPetIndex--;
            SwitchCard("left");
        }
        else if (currentPetIndex <= 0)
        {
            currentPetIndex = userPets.Count - 1;
            SwitchCard("left");
        }
    }
    private async Task SwitchCard(string direction)
    {
        if (direction == "right")
            animateDirection = "slide-right";
        if (direction == "left")
            animateDirection = "slide-left";
        StateHasChanged();
        await Task.Delay(300);

        animateDirection = "";
        StateHasChanged();
    }

    private async Task AddPet()
    {
        isAddMode = true;
        isEditMode = false;

        var newPet = new PetModel
        {
            date_of_birth = DateOnly.FromDateTime(DateTime.Today)
        };

        userPets.Add(newPet);
        currentPetIndex = userPets.Count - 1;
        SwitchCard("right");
    }

    private async Task DeletePet()
    {
        var deletePetResponse = await PetRequests.DeletePet(CurrentPet.id_pet);
        responseMessage = deletePetResponse.message;
        userPets.RemoveAt(currentPetIndex);

        currentPetIndex--;

        if (currentPetIndex < 0)
        {
            currentPetIndex = userPets.Count;
        }
        SwitchCard("left");
    }

    private async Task OnPetImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null)
            return;

        var imageUrl = await imageLoader.UploadImage(file);

        if (!string.IsNullOrEmpty(imageUrl))
        {
            CurrentPet.image = "http://localhost:5276" + imageUrl;
            StateHasChanged();
            responseMessage = "Сохраните, чтобы принять изменения.";
        }
    }

    private async Task OnProfileImageSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null)
            return;

        var imageUrl = await imageLoader.UploadImage(file);

        if (!string.IsNullOrEmpty(imageUrl))
        {
            updateUser.avatar = "http://localhost:5276" + imageUrl;
            StateHasChanged();
            responseMessage = "Сохраните, чтобы принять изменения.";
        }
    }

    private async Task SavePet()
    {
        if (string.IsNullOrWhiteSpace(CurrentPet.name) ||
            string.IsNullOrWhiteSpace(CurrentPet.breed) ||
            string.IsNullOrWhiteSpace(CurrentPet.species) ||
            string.IsNullOrWhiteSpace(CurrentPet.gender))
        {
            responseMessage = "Заполните все поля!";
            return;
        }
        ;

        if (isEditMode)
        {
            var updatePetResponse = await PetRequests.UpdatePet(CurrentPet);
            responseMessage = updatePetResponse.message;
        }
        else if (isAddMode)
        {
            CurrentPet.user_id = userService.CurrentUser.id_user;
            var addPetResponse = await PetRequests.AddPet(CurrentPet);
            responseMessage = addPetResponse.message;

            if (addPetResponse.status)
            {
                isAddMode = false;
                isEditMode = true;
            }
        }
    }

    private async Task SaveProfile()
    {
        if (string.IsNullOrWhiteSpace(updateUser.name) ||
            string.IsNullOrWhiteSpace(updateUser.surname) ||
            string.IsNullOrWhiteSpace(updateUser.gender) ||
            string.IsNullOrWhiteSpace(updateUser.email) ||
            string.IsNullOrWhiteSpace(updateUser.password) ||
            string.IsNullOrWhiteSpace(updateUser.phone))
        {
            responseMessage = "Заполните все поля!";
            return;
        }
        ;
        var updateProfileResponse = await UserRequests.UpdateUser(updateUser);
        if (updateProfileResponse.status)
        {
            responseMessage = updateProfileResponse.message;
            userService.Noitify();
        }
        else
            responseMessage = updateProfileResponse.message;


    }

    private async Task Logout()
    {
        userService.CurrentUser = null;
        await UserRequests.Logout();
        Navigation.NavigateTo("/authPage");
    }

}