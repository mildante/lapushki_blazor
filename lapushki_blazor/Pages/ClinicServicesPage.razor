@page "/servicesPage"

<PageTitle>Услуги</PageTitle>

@using lapushki_blazor.ApiRequests.Models
@using lapushki_blazor.ApiRequests.Services
@using static lapushki_blazor.ApiRequests.Models.Appointment
@using static lapushki_blazor.ApiRequests.Models.Pet
@using static lapushki_blazor.ApiRequests.Models.DoctorService
@using static lapushki_blazor.ApiRequests.Models.Doctor
@using static lapushki_blazor.ApiRequests.Models.ClinicService

@inject NavigationManager Navigation

<div class="services-page">
    <section class="animals-section">
        <h1 class="animals-title">Мы лечим любых животных</h1>

        <div class="animals-banner">
            <img src="/images/services_pets.png" alt="Мы лечим любых животных" />
        </div>
    </section>

    <section class="services-section">
        <h2 class="services-title">Услуги</h2>

        @if (services == null)
        {
            <div class="services-loading">Загрузка услуг...</div>
        }
        else if (services.Count == 0)
        {
            <div class="services-empty">Услуги пока не добавлены</div>
        }
        else
        {
            <div class="services-table-wrapper">
                <div class="services-table">
                    <div class="services-table-header">
                        <div class="service-name-col">Название услуги</div>
                        <div class="service-price-col">Стоимость</div>
                    </div>

                    @foreach (var service in services)
                    {
                        <div class="services-table-row">
                            <div class="service-name-col">
                                @service.name
                            </div>

                            <div class="service-price-col service-price-hover-cell">
                                <span class="service-price-text">@service.price ₽</span>

                                <button class="service-book-btn"
                                        @onclick="() => OpenBookingModal(isAuthorized, service)">
                                    Записаться
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </section>
    @if (isBookingModalOpen)
    {
        @if (isAuthorized)
        {
            <div class="booking-modal-overlay" @onclick="CloseBookingModal">
                <div class="booking-modal" @onclick:stopPropagation="true">
                    <button class="booking-modal-close" @onclick="CloseBookingModal">×</button>

                    <div class="booking-form">
                        <div class="booking-field">
                            <label>Ветеринарный врач</label>
                            <select @bind="selectedDoctorId">
                                @foreach (var doctor in doctors)
                                {
                                    <option value="@doctor.id_user">@doctor.user.name @doctor.user.surname, @doctor.specialization</option>
                                }
                            </select>
                        </div>

                        <div class="booking-field">
                            <label>Услуга</label>
                            <select @bind="selectedServiceId">
                                @foreach (var service in services)
                                {
                                    <option value="@service.id_service">@service.name</option>
                                }
                            </select>
                        </div>

                        <div class="booking-row">
                            <div class="booking-field">
                                <label>Дата</label>
                                <input type="date" @bind="selectedDate" />
                            </div>

                            <div class="booking-field">
                                <label>Доступное время</label>
                                <select @bind="selectedTime">
                                    @foreach (var slot in GetAvailableSlots())
                                    {
                                        <option value="@slot">@slot.ToString("HH:mm")</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="booking-field">
                            <label>Питомец</label>
                            <select @bind="selectedPetId">
                                @foreach (var pet in pets)
                                {
                                    <option value="@pet.id_pet">@pet.name, @pet.breed, @pet.species, @pet.date_of_birth</option>
                                }
                            </select>
                        </div>

                        <div class="booking-total">
                            <span>К оплате:</span>
                            <strong>@selectedServicePrice.ToString("0.00") ₽</strong>
                        </div>

                        <button class="booking-pay-btn">Оплатить</button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="booking-modal-overlay" @onclick="CloseBookingModal">
                <div class="booking-modal" @onclick:stopPropagation="true">
                    <button class="booking-modal-close" @onclick="CloseBookingModal">×</button>

                    <div class="booking-auth-required">
                        <h3>Сначала нужно авторизоваться</h3>
                        <p>Чтобы записаться на услугу, войдите в свой аккаунт</p>

                        <button type="button" class="booking-login-btn" @onclick="GoToLogin">
                            Войти
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Inject] private AppointmentRequests AppointmentRequests { get; set; }
    [Inject] private PetRequests PetRequests { get; set; }
    [Inject] private UserService userService { get; set; }

    private bool isAuthorized => userService.CurrentUser != null;

    private List<DoctorModel> doctors;
    private List<DoctorServiceModel> doctorServices;
    private List<ClinicServiceModel> services;
    private List<PetModel> pets;
    private List<AppointmentModel> bookedAppointments;

    private bool isBookingModalOpen = false;

    private int selectedServiceId;

    private int _selectedDoctorId;
    private int selectedDoctorId
    {
        get => _selectedDoctorId;
        set { _selectedDoctorId = value; _ = RefreshBookedSlots(); }
    }

    private int selectedPetId;

    private DoctorModel? selectedDoctor =>
        doctors?.FirstOrDefault(x => x.id_user == selectedDoctorId);

    private TimeOnly startTime => selectedDoctor?.work_start ?? new TimeOnly(9, 0);
    private TimeOnly endTime => selectedDoctor?.work_end ?? new TimeOnly(18, 0);

    private DateOnly _selectedDate;
    private DateOnly selectedDate
    {
        get => _selectedDate;
        set { _selectedDate = value; _ = RefreshBookedSlots(); }
    }

    private TimeOnly selectedTime;

    private double selectedServicePrice =>
        services?.FirstOrDefault(x => x.id_service == selectedServiceId)?.price ?? 0;

    protected override async Task OnInitializedAsync()
    {
        var getServicesResponse = await AppointmentRequests.GetAllCLinicServices();
        services = getServicesResponse.list;

        var getDoctorsResponse = await AppointmentRequests.GetAllDoctors();
        doctors = getDoctorsResponse.list;

        if (isAuthorized)
        {
            if (userService.CurrentUser.role_id == 3)
            {
                var getPetsResponse = await PetRequests.GetAllPetsByUser(userService.CurrentUser.id_user);
                pets = getPetsResponse.list;
            }
            else
            {
                var getPetsResponse = await PetRequests.GetAllPets();
                pets = getPetsResponse.list;
            }
        }  
    }

    private async void OpenBookingModal(bool isAuthorized, ClinicServiceModel service)
    {
        selectedServiceId = service.id_service;

        if (doctors != null && doctors.Count > 0)
            selectedDoctorId = doctors.First().id_user;

        if (pets != null && pets.Count > 0)
            selectedPetId = pets.First().id_pet;

        selectedDate = DateOnly.FromDateTime(DateTime.Today);
        await RefreshBookedSlots();
    
        var available = GetAvailableSlots();
        selectedTime = available.FirstOrDefault();
    
        isBookingModalOpen = true;
        StateHasChanged();
    }

    private void CloseBookingModal()
    {
        isBookingModalOpen = false;
    }

    private List<TimeOnly> GetAvailableSlots()
    {
        var slots = new List<TimeOnly>();
        if (selectedDoctor == null) return slots;

        var current = startTime;
        var duration = TimeSpan.FromMinutes(selectedDoctor.duration_slot);

        while (current.Add(duration) <= endTime)
        {
            bool isBusy = bookedAppointments.Any(x => x.time == current);

            bool isPast = selectedDate == DateOnly.FromDateTime(DateTime.Today) && current < TimeOnly.FromDateTime(DateTime.Now);

            if (!isBusy && !isPast)
            {
                slots.Add(current);
            }

            current = current.Add(duration);
        }

        return slots;
    }

    private async Task RefreshBookedSlots()
    {
        if (selectedDoctorId > 0)
        {
            var response = await AppointmentRequests.GetAllAppointmentsByDoctor(selectedDoctorId);
            bookedAppointments = response.list.Where(x => x.date == selectedDate).ToList();
        }
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/authPage");
    }
}