@page "/payment-success"
@using lapushki_blazor.ApiRequests.Services

@inject PaymentsApiService PaymentService
@inject NavigationManager Navigation

<h3>Статус оплаты</h3>

@if (isLoading)
{
    <p>Проверяем оплату...</p>
}
else
{
    <p>@statusText</p>
}

@code {
    private bool isLoading = true;
    private string statusText = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

            var appointmentIdValue = query["appointmentId"];

            if (!int.TryParse(appointmentIdValue, out var appointmentId))
            {
                statusText = "Не удалось определить запись ❌";
                return;
            }

            var result = await PaymentService.CheckPaymentStatusByAppointment(appointmentId);

            if (result != null && result.status)
            {
                if (result.paymentStatus == "Succeeded")
                    statusText = "Оплата прошла успешно ✅";
                else if (result.paymentStatus == "Pending")
                    statusText = "Платеж в процессе ⏳";
                else
                    statusText = "Оплата не выполнена ❌";
            }
            else
            {
                statusText = "Ошибка при проверке оплаты ❌";
            }
        }
        catch
        {
            statusText = "Ошибка при проверке оплаты ❌";
        }
        finally
        {
            isLoading = false;
        }
    }
}